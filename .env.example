PORT=3000
HOST=127.0.0.1

# SMTP settings for email notifications.
# Gmail usually requires an app password, not your regular account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ALERT_FROM=your-email@gmail.com
ALERT_TO=recipient@example.com

# Admin and abuse controls.
# Set ADMIN_TOKEN before exposing the dashboard beyond your own machine.
ADMIN_TOKEN=
REQUIRE_AUTH_FOR_READS=false
MAX_SITES=25
MIN_INTERVAL_MS=300000
MUTATION_RATE_WINDOW_MS=900000
MUTATION_RATE_MAX=30

# Restrict monitor targets. Leave ALLOWED_DOMAINS empty to allow any public hostname.
# Example: ALLOWED_DOMAINS=instructure.com,example.org
ALLOWED_DOMAINS=
BLOCK_PRIVATE_NETWORKS=true

# Notification dampening.
RECOVERY_CONFIRMATION_CHECKS=2
ALERT_COOLDOWN_MS=86400000

# Identify the checker politely. Add a contact URL or email if you monitor third-party sites.
CHECK_USER_AGENT=WebsiteHealthMonitor/0.1 (+https://github.com/michaelcwang/website_monitoring)
